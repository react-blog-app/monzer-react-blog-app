import { Link } from "react-router-dom";

export default function PostCard({ post }) {
  const preview =
    post.body.length > 100 ? post.body.substring(0, 100) + "..." : post.body;

  return (
    <div className="post-card">
      <h3>{post.title}</h3>
      <p>{preview}</p>
      <Link to={`/posts/${post.id}`} className="btn">
        Read More
      </Link>
    </div>
  );
}
